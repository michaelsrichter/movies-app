{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "platform": {
    "apiRuntime": "dotnet-isolated:9.0"
  },
  "routes": [
    {
      "route": "/admin",
      "rewrite": "/index.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/admin/*",
      "rewrite": "/index.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/manage/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous", "authenticated", "admin"]
    },
    {
      "route": "/login",
      "rewrite": "/.auth/login/github"
    },
    {
      "route": "/logout",
      "rewrite": "/.auth/logout"
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/github"
    },
    "404": {
      "rewrite": "/index.html"
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.{png,jpg,jpeg,gif,webp,svg,ico,css,js,txt,xml,json,webmanifest}"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": "default-src 'self'; img-src 'self' https://image.tmdb.org data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-src https://www.youtube-nocookie.com https://www.youtube.com; frame-ancestors 'none'; base-uri 'self'"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".webmanifest": "application/manifest+json",
    ".xml": "application/xml"
  }
}
