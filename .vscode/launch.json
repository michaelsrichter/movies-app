{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to .NET Functions",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:azureFunctions.pickProcess}"
    },
    {
      "name": "Launch Vite",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4280",
      "webRoot": "${workspaceFolder}/src"
    }
  ],
  "compounds": [
    {
      "name": "SWA: Functions + Vite",
      "configurations": ["Attach to .NET Functions", "Launch Vite"]
    }
  ]
}
