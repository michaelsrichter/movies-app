# Normalize line endings
* text=auto eol=lf

# Shell scripts keep LF
*.sh text eol=lf

# Windows-specific scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
